[user]
	name = Shota Hoshino
	email = sht.hshn@gmail.com
[core]
	excludesfile = ~/.gitignore
	whitespace = fix, -indent-with-no-tab, trailing-space, cr-at-eol
[push]
	default = simple
[alias]
	sync = fetch -pav
[pager]
	branch = false
[filter "lfs"]
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process
	required = true
